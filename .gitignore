# WaspSting .gitignore

# Output / reports (don't commit scan results)
output/
*.md.bak

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Secrets — NEVER commit these
.env
*.pem
*.key
secrets.json
config.local.*

# Temp files from scanning
/tmp/
waspsting_*/
*.tmp

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
